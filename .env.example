# ────────────────────────────────────────────────────────────
# Indian Legal Advisor – Environment configuration template
# ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
# Never commit .env – it is listed in .gitignore.

# AWS Configuration
AWS_REGION=us-east-2
AWS_PROFILE=your-aws-profile-name        # e.g. sandbox, default

# AWS OpenSearch Serverless (AOSS) endpoint  ← find in AWS console → AOSS → Collections
AOSS_URL=https://your-collection-id.us-east-2.aoss.amazonaws.com
INDEX_NAME=your-index-name

# S3 and DynamoDB
S3_BUCKET=your-s3-bucket-name
DYNAMODB_TABLE=your-dynamodb-table-name
CHAT_STORE_BACKEND=dynamodb              # options: dynamodb

# Foundation Model IDs (see AWS Bedrock console for available IDs)
LLM_MODEL=meta.llama3-3-70b-instruct-v1:0
ANSWER_MODEL=us.anthropic.claude-3-haiku-20240307-v1:0
FILTER_MODEL=us.anthropic.claude-3-haiku-20240307-v1:0
EMBED_MODEL=amazon.titan-embed-text-v2:0

# Logging – one of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
